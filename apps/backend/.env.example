# Ops API listener
OPS_API_ADDR=:8080

# Required for protected endpoints
OPS_API_ADMIN_TOKEN=change-me-to-a-strong-random-token
# Use a distinct producer-only token for ingest writes.
OPS_API_INGEST_TOKEN=change-me-to-a-separate-ingest-token

# Optional DB configuration
# Set true only for local smoke tests without a real database.
OPS_API_ALLOW_MEMORY_FALLBACK=true
OPS_API_DB_DRIVER=postgres
OPS_API_DB_DSN=

# HTTP server timeouts (seconds)
OPS_API_READ_TIMEOUT_SEC=10
OPS_API_WRITE_TIMEOUT_SEC=10

# Request body limits
OPS_API_INGEST_MAX_BODY_BYTES=1048576
OPS_API_SECURITY_MAX_BODY_BYTES=1048576

# Ingest retry worker
OPS_API_INGEST_RETRY_BASE_DELAY_MS=1000
OPS_API_INGEST_RETRY_MAX_DELAY_MS=30000
OPS_API_INGEST_RETRY_MAX_ATTEMPTS=5
OPS_API_INGEST_RETRY_WORKER_INTERVAL_MS=1000
OPS_API_INGEST_RETRY_BATCH_SIZE=20
